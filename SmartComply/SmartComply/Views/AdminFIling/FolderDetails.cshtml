@model IEnumerable<SmartComply.Models.FolderItem>

@{
    ViewData["Title"] = $"Items in {ViewBag.ComplianceFolderName} Folder";
}

<div id="sidebar" class="active">
    <div class="sidebar-wrapper active">
        <div class="sidebar-header">
            <div class="d-flex justify-content-between">
                <div class="logo">
                    <a href="/"><img src="~/assets/images/logo/logo.png" alt="Logo" /></a>
                </div>
                <div class="toggler">
                    <a href="#" class="sidebar-hide d-xl-none d-block"><i class="bi bi-x bi-middle"></i></a>
                </div>
            </div>
        </div>

        <div class="sidebar-menu">
            <ul class="menu">
                <li class="sidebar-title">Menu</li>

                <li class="sidebar-item ">
                    <a asp-controller="Admin" asp-action="Index" class='sidebar-link'>
                        <i class="bi bi-grid-fill"></i>
                        <span>Dashboard</span>
                    </a>
                </li>

                <li class="sidebar-item  ">
                    <a asp-controller="ComplianceFrameworks" asp-action="Index" class='sidebar-link'>
                        <i class="bi bi-file-earmark-medical-fill"></i>
                        <span>Compliance Framework</span>
                    </a>
                </li>

                <li class="sidebar-item ">
                    <a asp-controller="FoForm" asp-action="Index" class='sidebar-link'>
                        <i class="bi bi-file-earmark-medical-fill"></i>
                        <span>Dynamic Form</span>
                    </a>
                </li>

                <li class="sidebar-item active ">
                    <a asp-controller="AdminFiling" asp-action="Index" class='sidebar-link'>
                        <i class="bi bi-file-earmark-medical-fill"></i>
                        <span>Compliance Folder</span>
                    </a>
                </li>

                @if (User.Identity.IsAuthenticated)
                {
                    <li class="sidebar-item ">

                        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post" id="logoutForm" class="sidebar-form">

                            <button type="submit" class="sidebar-link w-100 text-start" style="background: none; border: none; padding: 0; margin: 0; color: inherit;">
                                <i class="bi bi-file-earmark-medical-fill"></i>
                                <span>Logout</span>
                            </button>
                            @Html.AntiForgeryToken() @* Essential for security! *@
                        </form>
                    </li>
                }
                else
                {
                    <li class="sidebar-item ">
                        <a asp-area="Identity" asp-page="/Account/Login" class='sidebar-link'>
                            <i class="bi bi-file-earmark-medical-fill"></i>
                            <span>Login</span>
                        </a>
                    </li>
                }

            </ul>
        </div>

        <button class="sidebar-toggler btn x"><i data-feather="x"></i></button>
    </div>
</div>

<div class="page-heading">
    <section class="section">
        <div class="card">
            <div class="card-header">
                <h2>Items for: @ViewBag.ComplianceFolderName</h2>
            </div>
            <div class="card-body">
                <p>
                    <a asp-action="AddItemsToFolder" asp-route-folderId="@ViewBag.ComplianceFolderId" class="btn btn-success">Add New Items</a>
                </p>

                @if (TempData["Message"] != null)
                {
                    <div class="alert alert-success" role="alert">
                        @TempData["Message"]
                    </div>
                }

                <table class="table table-striped table-bordered mt-3">
                    <thead class="thead-dark">
                        <tr>
                            <th>Item Name</th>
                            <th>Description</th>
                            <th>Required</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Name</td>
                                    <td>@(string.IsNullOrEmpty(item.Description) ? "N/A" : item.Description)</td>
                                    <td>@(item.IsRequired ? "Yes" : "No")</td>
                                    <td>
                                        <form asp-action="DeleteItem" asp-route-itemId="@item.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this item?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="complianceFolderId" value="@ViewBag.ComplianceFolderId" />
                                            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center">No items defined for this folder yet.</td>
                            </tr>
                        }
                    </tbody>
                </table>
                <p>
                    <a asp-action="Index" class="btn btn-secondary">Back to Folders List</a>
                </p>
            </div>
        </div>
    </section>
</div>

