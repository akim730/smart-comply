@model IEnumerable<SmartComply.Models.ComplianceFolder>

@{
    ViewData["Title"] = "Manage Compliance Folders";
}

<div id="sidebar" class="active">
    <div class="sidebar-wrapper active">
        <div class="sidebar-header">
            <div class="d-flex justify-content-between">
                <div class="logo">
                    <a href="/"><img src="~/assets/images/logo/logo.png" alt="Logo" /></a>
                </div>
                <div class="toggler">
                    <a href="#" class="sidebar-hide d-xl-none d-block"><i class="bi bi-x bi-middle"></i></a>
                </div>
            </div>
        </div>

        <div class="sidebar-menu">
            <ul class="menu">
                <li class="sidebar-title">Menu</li>

                <li class="sidebar-item ">
                    <a asp-controller="Admin" asp-action="Index" class='sidebar-link'>
                        <i class="bi bi-grid-fill"></i>
                        <span>Dashboard</span>
                    </a>
                </li>

                <li class="sidebar-item  ">
                    <a asp-controller="ComplianceFrameworks" asp-action="Index" class='sidebar-link'>
                        <i class="bi bi-file-earmark-medical-fill"></i>
                        <span>Compliance Framework</span>
                    </a>
                </li>

                <li class="sidebar-item ">
                    <a asp-controller="FoForm" asp-action="Index" class='sidebar-link'>
                        <i class="bi bi-file-earmark-medical-fill"></i>
                        <span>Dynamic Form</span>
                    </a>
                </li>

                <li class="sidebar-item active ">
                    <a asp-controller="AdminFiling" asp-action="Index" class='sidebar-link'>
                        <i class="bi bi-file-earmark-medical-fill"></i>
                        <span>Compliance Folder</span>
                    </a>
                </li>

                @if (User.Identity.IsAuthenticated)
                {
                    <li class="sidebar-item ">

                        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post" id="logoutForm" class="sidebar-form">

                            <button type="submit" class="sidebar-link w-100 text-start" style="background: none; border: none; padding: 0; margin: 0; color: inherit;">
                                <i class="bi bi-file-earmark-medical-fill"></i>
                                <span>Logout</span>
                            </button>
                            @Html.AntiForgeryToken() @* Essential for security! *@
                        </form>
                    </li>
                }
                else
                {
                    <li class="sidebar-item ">
                        <a asp-area="Identity" asp-page="/Account/Login" class='sidebar-link'>
                            <i class="bi bi-file-earmark-medical-fill"></i>
                            <span>Login</span>
                        </a>
                    </li>
                }

            </ul>
        </div>

        <button class="sidebar-toggler btn x"><i data-feather="x"></i></button>
    </div>
</div>

<div class="page-heading">
    <section class="section">
        <div class="card">
            <div class="card-header">
                <h2>Compliance Folder</h2>
            </div>
            <div class="card-body">
                <p>
                    <a asp-action="CreateFolder" class="btn btn-primary">Create New Folder</a>
                </p>

                @if (TempData["Message"] != null)
                {
                    <div class="alert alert-success" role="alert">
                        @TempData["Message"]
                    </div>
                }

                <table class="table table-striped table-bordered mt-3">
                    <thead class="thead-dark">
                        <tr>
                            <th>Folder Name</th>
                            <th>Compliance Type</th>
                            <th>Created At</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var folder in Model)
                            {
                                <tr>
                                    <td>@folder.Name</td>
                                    <td>@folder.AmCompliance.ComplianceName</td>
                                    <td>@folder.CreatedAt.ToShortDateString()</td>
                                    <td>
                                        <a asp-action="FolderDetails" asp-route-id="@folder.Id" class="btn btn-sm btn-info">View Items</a>
                                        <a asp-action="AddItemsToFolder" asp-route-folderId="@folder.Id" class="btn btn-sm btn-secondary">Add Items</a>

                                        @* Added Delete Button for Folder *@
                                        <form asp-action="DeleteFolder" asp-route-id="@folder.Id" method="post" onsubmit="return confirm('Are you sure you want to delete the folder \'@folder.Name\' and all its associated items and filings? This action cannot be undone.');" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center">No compliance folders created yet.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </section>
</div>
