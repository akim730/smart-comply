@model IEnumerable<SmartComply.ViewModels.ComplianceFrameworkListItemViewModel>

@{
    ViewData["Title"] = "Index";
}
<div id="sidebar" class="active">
    <div class="sidebar-wrapper active">
        <div class="sidebar-header">
            <div class="d-flex justify-content-between">
                <div class="logo">
                    <a href="/"><img src="~/assets/images/logo/logo.png" alt="Logo" /></a>
                </div>
                <div class="toggler">
                    <a href="#" class="sidebar-hide d-xl-none d-block"><i class="bi bi-x bi-middle"></i></a>
                </div>
            </div>
        </div>

        <div class="sidebar-menu">
            <ul class="menu">
                <li class="sidebar-title">Menu</li>

                <li class="sidebar-item ">
                    <a asp-controller="Admin" asp-action="Index" class='sidebar-link'>
                        <i class="bi bi-grid-fill"></i>
                        <span>Dashboard</span>
                    </a>
                </li>

                <li class="sidebar-item active ">
                    <a asp-controller="ComplianceFrameworks" asp-action="Index" class='sidebar-link'>
                        <i class="bi bi-file-earmark-medical-fill"></i>
                        <span>Compliance Framework</span>
                    </a>
                </li>

                <li class="sidebar-item ">
                    <a asp-controller="FoForm" asp-action="Index" class='sidebar-link'>
                        <i class="bi bi-file-earmark-medical-fill"></i>
                        <span>Dynamic Form</span>
                    </a>
                </li>

                <li class="sidebar-item  ">
                    <a asp-controller="AdminFiling" asp-action="Index" class='sidebar-link'>
                        <i class="bi bi-file-earmark-medical-fill"></i>
                        <span>Compliance Folder</span>
                    </a>
                </li>

                @if (User.Identity.IsAuthenticated)
                {
                    <li class="sidebar-item ">

                        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post" id="logoutForm" class="sidebar-form">

                            <button type="submit" class="sidebar-link w-100 text-start" style="background: none; border: none; padding: 0; margin: 0; color: inherit;">
                                <i class="bi bi-file-earmark-medical-fill"></i>
                                <span>Logout</span>
                            </button>
                            @Html.AntiForgeryToken() @* Essential for security! *@
                        </form>
                    </li>
                }
                else
                {
                    <li class="sidebar-item ">
                        <a asp-area="Identity" asp-page="/Account/Login" class='sidebar-link'>
                            <i class="bi bi-file-earmark-medical-fill"></i>
                            <span>Login</span>
                        </a>
                    </li>
                }

            </ul>
        </div>

        <button class="sidebar-toggler btn x"><i data-feather="x"></i></button>
    </div>
</div>


<div class="page-heading">
    <div class="page-title">
        <div class="row">
            <div class="col-12 col-md-6 order-md-1 order-last">
                <h3>Compliance Frameworks</h3> @* This heading can be changed to "Compliance Overview" or "Dashboard Statistics" *@
            </div>
            <div class="col-12 col-md-6 order-md-2 order-first">
                <nav aria-label="breadcrumb" class="breadcrumb-header float-start float-lg-end">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Index">Dashboard</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Dynamic Form</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
    <section class="section">
        <div class="card">
            <div class="card-header">
                <h4 class="card-title">All Compliance</h4>
            </div>
            <div class="card-body">
                <p>
                    <a asp-action="Create" class="btn btn-primary">Create New Compliance</a>
                </p>

                <table class="table">
                    <thead>
                        <tr>
                            <th>
                                @Html.DisplayNameFor(model => model.ComplianceName)
                            </th>
                            <th>
                                @Html.DisplayNameFor(model => model.ComplianceDescription)
                            </th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    @Html.DisplayFor(modelItem => item.ComplianceName)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.ComplianceDescription)
                                </td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-secondary">Details</a> |
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning">Edit</a> |
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this item?');">
                                        <button type="submit" class="btn btn-danger">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </section>
   
</div>



