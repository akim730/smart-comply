@model SmartComply.ViewModels.FilingUploadViewModel

@{
    ViewData["Title"] = $"Upload Document for {Model.FolderItemName}";
}

<div class="container mt-4">
    <h1>Upload Document</h1>

    <h3>Folder: @Model.ComplianceFolderName</h3>
    <h4>Item: @Model.FolderItemName</h4>

    <div class="row">
        <div class="col-md-6">
            <form asp-action="Upload" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="FolderItemId" />

                <div class="form-group mb-3">
                    <label asp-for="File" class="control-label"></label>
                    <input asp-for="File" type="file" class="form-control" />
                    <span asp-validation-for="File" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Tags" class="control-label"></label>
                    <input asp-for="Tags" class="form-control" placeholder="e.g., Q1, 2024, Draft" />
                    <span asp-validation-for="Tags" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <button type="submit" class="btn btn-primary">Upload</button>
                    <a asp-action="ItemsInFolder" asp-route-folderId="@ViewBag.ComplianceFolderId" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}