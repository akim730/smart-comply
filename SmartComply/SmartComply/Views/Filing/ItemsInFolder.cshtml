@model IEnumerable<SmartComply.Models.FolderItem>

@{
    ViewData["Title"] = $"Items in {ViewBag.ComplianceFolderName}";
}

<div class="container mt-4">
    <h1>Items for Folder: @ViewBag.ComplianceFolderName</h1>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success" role="alert">
            @TempData["Message"]
        </div>
    }

    <table class="table table-striped table-bordered mt-3">
        <thead class="thead-dark">
            <tr>
                <th>Item Name</th>
                <th>Description</th>
                <th>Required</th>
                <th>Actions</th>
                <th>Uploaded Documents</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@(string.IsNullOrEmpty(item.Description) ? "N/A" : item.Description)</td>
                        <td>@(item.IsRequired ? "Yes" : "No")</td>
                        <td>
                            <a asp-action="Upload" asp-route-folderItemId="@item.Id" class="btn btn-sm btn-success">Upload Document</a>
                        </td>
                        <td>
                            @if (item.FilingDocuments != null && item.FilingDocuments.Any())
                            {
                                <ul class="list-unstyled">
                                    @foreach (var doc in item.FilingDocuments)
                                    {
                                        <li>
                                            <a asp-action="Download" asp-route-id="@doc.Id" target="_blank">@doc.FileName</a>
                                            (Uploaded: @doc.UploadedAt.ToShortDateString())
                                            <a asp-action="Delete" asp-route-id="@doc.Id" class="btn btn-danger btn-sm ms-2" onclick="return confirm('Are you sure you want to delete this file?');">Delete</a>
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <span>No documents uploaded yet.</span>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="text-center">No items defined for this folder yet.</td>
                </tr>
            }
        </tbody>
    </table>
    <p>
        <a asp-action="Index" class="btn btn-secondary">Back to Folders List</a>
    </p>
</div>