@model IEnumerable<SmartComply.Models.ComplianceFolder>

@{
    ViewData["Title"] = "My Compliance Folders";
}

<div class="container mt-4">
    <h1>Compliance Folders for You</h1>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success" role="alert">
            @TempData["Message"]
        </div>
    }

    <table class="table table-striped table-bordered mt-3">
        <thead class="thead-dark">
            <tr>
                <th>Folder Name</th>
                <th>Compliance Type</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var folder in Model)
                {
                    <tr>
                        <td>@folder.Name</td>
                        <td>@folder.AmCompliance.ComplianceName</td>
                        <td>
                            <a asp-action="ItemsInFolder" asp-route-folderId="@folder.Id" class="btn btn-sm btn-primary">View Items & Upload</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="3" class="text-center">No compliance folders available for you.</td>
                </tr>
            }
        </tbody>
    </table>
</div>