<div class="page-heading">
    <div class="page-title">
        <div class="row">
            <div class="col-12 col-md-6 order-md-1 order-last">
                <h3>Files for @title</h3>
            </div>
            <div class="col-12 col-md-6 order-md-2 order-first">
                <nav aria-label="breadcrumb" class="breadcrumb-header float-start float-lg-end">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Index">Dashboard</a></li>
                        <li class="breadcrumb-item"><a asp-controller="Filing" asp-action="Index">Filing</a></li>
                        <li class="breadcrumb-item active" aria-current="page">@title</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>

    <section class="section">
        <div class="card">
            <div class="card-header">
                <h4 class="card-title">Uploaded Documents</h4>
            </div>

            <div class="card-body">
                @if (TempData["Message"] != null)
                {
                    <div class="alert alert-success">@TempData["Message"]</div>
                }

                @if (!Model.Any())
                {
                    <p class="text-muted">No files uploaded yet for this compliance group.</p>
                }
                else
                {
                    <table class="table table-bordered table-hover">
                        <thead class="bg-light">
                            <tr>
                                <th>File Name</th>
                                <th>Tags</th>
                                <th>Uploaded At</th>
                                <th style="width: 200px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var file in Model)
                            {
                                <tr>
                                    <td>@file.FileName</td>
                                    <td>@file.Tags</td>
                                    <td>@file.UploadedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>
                                        <a href="@file.FilePath" target="_blank" class="btn btn-sm btn-outline-primary me-2">
                                            Download
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@file.Id" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure you want to delete this file?');">
                                            Delete
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }

                <a asp-action="Upload" asp-route-filingTitle="@title" class="btn btn-primary mt-3">Upload New File</a>
                <a asp-action="Index" class="btn btn-secondary mt-3 ms-2">Back to Filing List</a>
            </div>
        </div>
    </section>
</div>
