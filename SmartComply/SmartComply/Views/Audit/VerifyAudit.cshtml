@model SmartComply.ViewModels.AuditVerificationViewModel
@{
    ViewData["Title"] = "Verify Audit";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="page-title-box">
                <h4 class="page-title">Audit Verification</h4>
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Dashboard</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("ManagerDashboard")">Manager Dashboard</a></li>
                    <li class="breadcrumb-item active">Verify Audit</li>
                </ol>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Audit Details -->
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-clipboard-check me-1"></i>
                        Audit Details
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <table class="table table-borderless">
                                <tr>
                                    <th width="40%">Audit Title:</th>
                                    <td>@Model.Audit.AuditTitle</td>
                                </tr>
                                <tr>
                                    <th>Description:</th>
                                    <td>@Model.Audit.AuditDescription</td>
                                </tr>
                                <tr>
                                    <th>Compliance:</th>
                                    <td>@Model.Audit.Compliance?.ComplianceName</td>
                                </tr>
                                <tr>
                                    <th>Form:</th>
                                    <td>@Model.Audit.Form?.FoName</td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <table class="table table-borderless">
                                <tr>
                                    <th width="40%">Audit Date:</th>
                                    <td>@Model.Audit.AuditDate.ToString("MMM dd, yyyy")</td>
                                </tr>
                                <tr>
                                    <th>Completed Date:</th>
                                    <td>
                                        @if (Model.Audit.CompletedDate.HasValue)
                                        {
                                            @Model.Audit.CompletedDate.Value.ToString("MMM dd, yyyy HH:mm")
                                        }
                                        else
                                        {
                                            <span class="text-muted">Not completed</span>
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <th>Score:</th>
                                    <td>
                                        @if (Model.Audit.AuditScore.HasValue)
                                        {
                                            <span class="badge bg-@(Model.Audit.AuditScore.Value >= 80 ? "success" : Model.Audit.AuditScore.Value >= 60 ? "warning" : "danger") fs-6">
                                                @Model.Audit.AuditScore.Value%
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">No score</span>
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <th>Status:</th>
                                    <td>
                                        <span class="badge bg-@(Model.Audit.AuditStatus == "Completed" ? "success" : "primary")">
                                            @Model.Audit.AuditStatus
                                        </span>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Audit.AuditFindings))
                    {
                        <div class="mt-3">
                            <h6>Audit Findings:</h6>
                            <div class="bg-light p-3 rounded">
                                @Model.Audit.AuditFindings
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.Audit.AuditNotes))
                    {
                        <div class="mt-3">
                            <h6>Audit Notes:</h6>
                            <div class="bg-light p-3 rounded">
                                @Model.Audit.AuditNotes
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Audit Responses -->
            @if (Model.AuditResponses.Any())
            {
                <div class="card mt-3">
                    <div class="card-header">
                        <h5 class="card-title mb-0">
                            <i class="fas fa-list-check me-1"></i>
                            Audit Responses
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Question</th>
                                        <th>Response</th>
                                        <th>Compliant</th>
                                        <th>Notes</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var response in Model.AuditResponses)
                                    {
                                        <tr>
                                            <td>@response.QuestionText</td>
                                            <td>@response.ResponseValue</td>
                                            <td>
                                                @if (response.IsCompliant.HasValue)
                                                {
                                                    <span class="badge bg-@(response.IsCompliant.Value ? "success" : "danger")">
                                                        @(response.IsCompliant.Value ? "Yes" : "No")
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">N/A</span>
                                                }
                                            </td>
                                            <td>@response.ResponseNotes</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Verification Panel -->
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-stamp me-1"></i>
                        Verification Decision
                    </h5>
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(Model.Audit.VerificationStatus) && Model.Audit.VerificationStatus != "Pending")
                    {
                        <div class="alert alert-info">
                            <h6>Previous Verification</h6>
                            <p><strong>Status:</strong> @Model.Audit.VerificationStatus</p>
                            @if (Model.Audit.VerifiedAt.HasValue)
                            {
                                <p><strong>Verified At:</strong> @Model.Audit.VerifiedAt.Value.ToString("MMM dd, yyyy HH:mm")</p>
                            }
                            @if (!string.IsNullOrEmpty(Model.Audit.VerificationComments))
                            {
                                <p><strong>Comments:</strong> @Model.Audit.VerificationComments</p>
                            }
                        </div>
                    }

                    @if (Model.VerificationStatus == "Pending" || string.IsNullOrEmpty(Model.VerificationStatus))
                    {
                        <form asp-action="SubmitVerification" method="post">
                            @Html.AntiForgeryToken()
                            @Html.HiddenFor(m => m.Audit.Id)
                            <div class="mb-3">
                                <label asp-for="NewVerificationComments"></label> <textarea asp-for="NewVerificationComments" class="form-control"></textarea>
                            </div>
                            <button type="submit" name="NewVerificationStatus" value="Approved" class="btn btn-success">Approve</button> <button type="submit" name="NewVerificationStatus" value="Rejected" class="btn btn-danger">Reject</button>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            This audit has already been @Model.VerificationStatus.
                        </div>
                    }
                </div>
            </div>

            <!-- Verification Guidelines -->
            <div class="card mt-3">
                <div class="card-header">
                    <h6 class="card-title mb-0">
                        <i class="fas fa-info-circle me-1"></i>
                        Verification Guidelines
                    </h6>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled small">
                        <li class="mb-2">
                            <i class="fas fa-check-circle text-success me-1"></i>
                            <strong>Approve:</strong> Audit is complete and accurate
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-times-circle text-danger me-1"></i>
                            <strong>Reject:</strong> Audit has significant issues
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-edit text-warning me-1"></i>
                            <strong>Requires Revision:</strong> Minor corrections needed
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>


    @section Scripts {  
        <script>  
            $(function() {  
                // Confirmation for verification submission  
                $('form').on('submit', function(e) {  
                    var status = $('#verificationStatus').val();  
                    if (status && !confirm('Are you sure you want to ' + status.toLowerCase() + ' this audit?')) {  
                        e.preventDefault();  
                    }  
                });  
            });  
        </script>  
    }

