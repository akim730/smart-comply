@model List<SmartComply.Models.CorrectivePlan>
@{
    ViewData["Title"] = "Pending Corrective Plan Approvals";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="page-title-box">
                <h4 class="page-title">Pending Corrective Plan Approvals</h4>
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Dashboard</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("ManagerDashboard", "Audit")">Manager Dashboard</a></li>
                    <li class="breadcrumb-item active">Pending Approvals</li>
                </ol>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="card-title mb-0">
                            <i class="fas fa-tasks me-1"></i>
                            Corrective Plans Requiring Approval (@Model.Count)
                        </h5>
                        <div>
                            <a href="@Url.Action("ManagerDashboard", "Audit")" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-1"></i>
                                Back to Dashboard
                            </a>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    @if (Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th>Issue Identified</th>
                                        <th>Corrective Action</th>
                                        <th>Priority</th>
                                        <th>Target Date</th>
                                        <th>Related Audit</th>
                                        <th>Created Date</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var plan in Model)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@plan.IssueIdentified</strong>
                                                @if (!string.IsNullOrEmpty(plan.ProgressNotes))
                                                {
                                                    <br><small class="text-muted">@plan.ProgressNotes</small>
                                                }
                                            </td>
                                            <td>
                                                <div class="text-truncate" style="max-width: 200px;" title="@plan.CorrectiveAction">
                                                    @plan.CorrectiveAction
                                                </div>
                                            </td>
                                            <td>
                                                <span class="badge bg-@(plan.Priority == "High" ? "danger" : plan.Priority == "Medium" ? "warning" : "info")">
                                                    @plan.Priority
                                                </span>
                                            </td>
                                            <td>
                                                @plan.TargetCompletionDate.ToString("MMM dd, yyyy")
                                                @if (plan.TargetCompletionDate < DateTime.Today)
                                                {
                                                    <br><small class="text-danger"><i class="fas fa-exclamation-triangle"></i> Overdue</small>
                                                }
                                                else if (plan.TargetCompletionDate <= DateTime.Today.AddDays(7))
                                                {
                                                    <br><small class="text-warning"><i class="fas fa-clock"></i> Due Soon</small>
                                                }
                                            </td>
                                            <td>
                                                @if (plan.Audit != null)
                                                {
                                                    <div>
                                                        <strong>@plan.Audit.AuditTitle</strong>
                                                        <br><small class="text-muted">@plan.Audit.Compliance?.ComplianceName</small>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">N/A</span>
                                                }
                                            </td>
                                            <td>
                                                @plan.CreatedAt.ToString("MMM dd, yyyy")
                                                <br><small class="text-muted">@plan.CreatedAt.ToString("HH:mm")</small>
                                            </td>
                                            <td>
                                                <div class="btn-group" role="group">
                                                    <a href="@Url.Action("Details", new { id = plan.Id })" class="btn btn-outline-info btn-sm" title="View Details">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    <a href="@Url.Action("ApproveCorrectivePlan", new { id = plan.Id })" class="btn btn-outline-success btn-sm" title="Approve">
                                                        <i class="fas fa-check"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <!-- Bulk Actions -->
                        <div class="mt-3">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="d-flex align-items-center">
                                        <label class="form-label me-2 mb-0">Bulk Actions:</label>
                                        <select id="bulkAction" class="form-select me-2" style="width: auto;">
                                            <option value="">Select Action</option>
                                            <option value="approve">Approve Selected</option>
                                            <option value="reject">Reject Selected</option>
                                        </select>
                                        <button type="button" id="applyBulkAction" class="btn btn-outline-primary btn-sm">Apply</button>
                                    </div>
                                </div>
                                <div class="col-md-6 text-end">
                                    <div class="text-muted small">
                                        <i class="fas fa-info-circle"></i>
                                        Select checkboxes to use bulk actions
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-check-circle fa-4x text-success mb-3"></i>
                            <h4>No Pending Approvals</h4>
                            <p class="text-muted">All corrective plans have been approved or processed.</p>
                            <a href="@Url.Action("Index")" class="btn btn-outline-primary">
                                <i class="fas fa-list me-1"></i>
                                View All Corrective Plans
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Initialize DataTable
            if ($.fn.DataTable) {
                $('.table').DataTable({
                    "pageLength": 25,
                    "order": [[ 5, "desc" ]], // Sort by created date desc
                    "columnDefs": [
                        { "orderable": false, "targets": [6] }, // Actions column
                        { "targets": [0], "width": "25%" },
                        { "targets": [1], "width": "25%" }
                    ]
                });
            }

            // Bulk actions functionality
            $('#applyBulkAction').on('click', function() {
                var action = $('#bulkAction').val();
                var selectedIds = [];
                
                $('input[name="selectedPlans"]:checked').each(function() {
                    selectedIds.push($(this).val());
                });

                if (!action) {
                    alert('Please select an action.');
                    return;
                }

                if (selectedIds.length === 0) {
                    alert('Please select at least one corrective plan.');
                    return;
                }

                if (confirm('Are you sure you want to ' + action + ' ' + selectedIds.length + ' corrective plan(s)?')) {
                    // Implement bulk action logic here
                    console.log('Bulk action:', action, 'IDs:', selectedIds);
                }
            });

            // Select all checkbox functionality
            $('#selectAll').on('change', function() {
                $('input[name="selectedPlans"]').prop('checked', this.checked);
            });
        });
    </script>
}
