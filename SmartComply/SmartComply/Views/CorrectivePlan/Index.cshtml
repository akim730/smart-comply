@model IEnumerable<SmartComply.Models.CorrectivePlan>

@{
    ViewData["Title"] = "Corrective Action Plans";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-header bg-warning text-dark">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">
                            <i class="fas fa-clipboard-check me-2"></i>Corrective Action Plans
                        </h4>
                        <a asp-action="Create" class="btn btn-success">
                            <i class="fas fa-plus me-2"></i>Create Action Plan
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    @if (!Model.Any())
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-clipboard-check fa-3x text-muted mb-3"></i>
                            <h5 class="text-muted">No corrective action plans found</h5>
                            <p class="text-muted">Create your first action plan to track corrective measures.</p>
                            <a asp-action="Create" class="btn btn-primary">
                                <i class="fas fa-plus me-2"></i>Create Action Plan
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Issue</th>
                                        <th>Corrective Action</th>
                                        <th>Audit</th>
                                        <th>Priority</th>
                                        <th>Status</th>
                                        <th>Target Date</th>
                                        <th>Progress</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        var statusBadgeClass = item.Status switch
                                        {
                                            "Pending" => "bg-warning",
                                            "InProgress" => "bg-info",
                                            "Completed" => "bg-success",
                                            "Overdue" => "bg-danger",
                                            _ => "bg-secondary"
                                        };

                                        var priorityBadgeClass = item.Priority switch
                                        {
                                            "High" => "bg-danger",
                                            "Medium" => "bg-warning",
                                            "Low" => "bg-info",
                                            _ => "bg-secondary"
                                        };

                                        var isOverdue = item.TargetCompletionDate < DateTime.Now && item.Status != "Completed";
                                        
                                        <tr class="@(isOverdue ? "table-danger" : "")">
                                            <td>
                                                <strong>@item.IssueIdentified</strong>
                                                @if (isOverdue)
                                                {
                                                    <i class="fas fa-exclamation-triangle text-danger ms-2" title="Overdue"></i>
                                                }
                                            </td>
                                            <td>@item.CorrectiveAction.Substring(0, Math.Min(item.CorrectiveAction.Length, 100))@(item.CorrectiveAction.Length > 100 ? "..." : "")</td>
                                            <td>@(item.Audit?.AuditTitle ?? "N/A")</td>
                                            <td><span class="badge @priorityBadgeClass">@item.Priority</span></td>
                                            <td><span class="badge @statusBadgeClass">@item.Status</span></td>
                                            <td>@item.TargetCompletionDate.ToString("MMM dd, yyyy")</td>
                                            <td>
                                                @if (item.ActualCompletionDate.HasValue)
                                                {
                                                    <span class="text-success">
                                                        <i class="fas fa-check-circle me-1"></i>
                                                        Completed @item.ActualCompletionDate.Value.ToString("MMM dd, yyyy")
                                                    </span>
                                                }
                                                else
                                                {
                                                    var daysDiff = (item.TargetCompletionDate - DateTime.Now).Days;
                                                    if (daysDiff < 0)
                                                    {
                                                        <span class="text-danger">@Math.Abs(daysDiff) days overdue</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-info">@daysDiff days remaining</span>
                                                    }
                                                }
                                            </td>
                                            <td>
                                                <div class="btn-group" role="group">
                                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    @if (item.Status != "Completed")
                                                    {
                                                        <button type="button" class="btn btn-sm btn-outline-success" onclick="updateStatus(@item.Id, 'Completed')">
                                                            <i class="fas fa-check"></i>
                                                        </button>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<form method="post" style="display:none">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
    <script>
        function updateStatus(id, status) {
            if (confirm('Are you sure you want to mark this action plan as ' + status.toLowerCase() + '?')) {
                $.ajax({
                    url: '@Url.Action("UpdateStatus")',
                    type: 'POST',
                    data: {
                        id: id,
                        status: status,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(result) {
                        location.reload();
                    },
                    error: function() {
                        alert('Error updating status');
                    }
                });
            }
        }
    </script>
}
